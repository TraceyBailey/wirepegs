---
import Layout from '../../layouts/Layout.astro';

const posts = Object.values(import.meta.glob('./*.md', { eager: true })) as any[];
const sortedPosts = posts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Layout
  title="Wire Pegs Blog — Guides, Tips & Advice"
  description="The Wire Pegs blog. Guides, tips and advice on choosing the right stainless steel peg, sustainable laundry, and making the most of your wire pegs."
>

  <section class="py-24 px-6 bg-navy-50">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-teal-500 mb-4">Tips & Guides</p>
      <h1 class="text-4xl md:text-5xl font-bold text-navy-900 leading-tight mb-6">The Wire Pegs Blog</h1>
      <p class="text-xl text-navy-600 leading-relaxed">Everything you need to know about stainless steel pegs, sustainable laundry, and getting the most from your Wire Pegs.</p>
    </div>
  </section>

  <section class="py-16 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-navy-400 text-lg">Blog posts coming soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {sortedPosts.map((post: any) => (
            <a href={post.url} class="bg-navy-50 rounded-2xl border border-navy-100 p-8 hover:border-teal-500 transition-colors group">
              <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-3">{post.frontmatter.category}</p>
              <h2 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-teal-500 transition-colors">{post.frontmatter.title}</h2>
              <p class="text-navy-600 text-sm leading-relaxed mb-4">{post.frontmatter.description}</p>
              <p class="text-xs text-navy-400">{new Date(post.frontmatter.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</Layout>