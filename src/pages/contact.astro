---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Wire Pegs"
  description="Get in touch with Wire Pegs. To order products, visit Biome. For all other enquiries, such as wholesale, contact us using the form below."
>

  <section class="py-24 px-6 bg-navy-50">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-teal-500 mb-4">Get In Touch</p>
      <h1 class="text-4xl md:text-5xl font-bold text-navy-900 leading-tight mb-6">Contact Us</h1>
      <p class="text-xl text-navy-600 leading-relaxed">Have a question about Wire Pegs? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="py-16 px-6 bg-white">
    <div class="max-w-3xl mx-auto">

      <div class="bg-navy-900 text-white rounded-2xl p-8 mb-8">
        <h2 class="text-xl font-bold mb-3">Looking to buy Wire Pegs?</h2>
        <p class="text-navy-100 leading-relaxed mb-6">Wire Pegs are available exclusively through Biome. Head to their website to browse the full range and place an order.</p>
        <a href="https://www.biome.com.au/collections/wire-pegs" target="_blank" class="bg-teal-500 text-white font-semibold px-8 py-4 rounded-full hover:bg-teal-700 transition-colors inline-block">Shop at Biome →</a>
      </div>

      <div class="bg-navy-50 rounded-2xl border border-navy-100 p-8 mb-8">
        <h2 class="text-xl font-bold text-navy-900 mb-6">Send us a message</h2>
        <form
          action="https://formspree.io/f/mwvjapbz"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="name">Your name</label>
            <input type="text" id="name" name="name" required class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors bg-white" placeholder="Jane Smith" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="email">Your email</label>
            <input type="email" id="email" name="email" required class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors bg-white" placeholder="jane@example.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="message">Message</label>
            <textarea id="message" name="message" required rows="5" class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors resize-none bg-white" placeholder="Your message here..."></textarea>
          </div>
          <button type="submit" class="bg-teal-500 text-white font-semibold px-8 py-4 rounded-full hover:bg-teal-700 transition-colors w-full">Send Message</button>
        </form>
      </div>

      <p class="text-center text-navy-400 text-sm">We aim to respond to all enquiries within 1–2 business days.</p>

    </div>
  </section>

  <section id="wholesale" class="py-16 px-6 border-t border-navy-100 bg-navy-50">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl border border-navy-100 p-8">
        <h2 class="text-xl font-bold text-navy-900 mb-2">Looking to sell Wire Pegs in your store?</h2>
        <p class="text-navy-600 text-sm leading-relaxed mb-6">We welcome wholesale enquiries from retailers who share our values around quality and sustainability. Fill in the form below and we'll be in touch.</p>
        <form
          action="https://formspree.io/f/mwvjapbz"
          method="POST"
          class="space-y-6"
        >
          <input type="hidden" name="enquiry_type" value="Wholesale" />
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="wholesale-name">Your name</label>
            <input type="text" id="wholesale-name" name="name" required class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors bg-white" placeholder="Jane Smith" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="wholesale-business">Business name</label>
            <input type="text" id="wholesale-business" name="business" required class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors bg-white" placeholder="Your Store Name" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="wholesale-email">Email address</label>
            <input type="email" id="wholesale-email" name="email" required class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors bg-white" placeholder="jane@yourstore.com.au" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2" for="wholesale-message">Tell us about your store</label>
            <textarea id="wholesale-message" name="message" required rows="4" class="w-full border border-navy-100 rounded-xl px-4 py-3 text-navy-900 focus:outline-none focus:border-teal-500 transition-colors resize-none bg-white" placeholder="Where are you located, what do you sell, how did you hear about us..."></textarea>
          </div>
          <button type="submit" class="bg-teal-500 text-white font-semibold px-8 py-4 rounded-full hover:bg-teal-700 transition-colors w-full">Send Wholesale Enquiry</button>
        </form>
      </div>
    </div>
  </section>

</Layout>