---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Peg Finder — Which Wire Peg Is Right for You?"
  description="Answer 3 quick questions and we'll recommend the perfect stainless steel wire peg for your conditions. Find your ideal peg in under a minute."
>

  <section class="py-24 px-6 bg-navy-50">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-teal-500 mb-4">Quick Tool</p>
      <h1 class="text-4xl md:text-5xl font-bold text-navy-900 leading-tight mb-6">Find Your Perfect Peg</h1>
      <p class="text-xl text-navy-600 leading-relaxed">Answer 3 quick questions and we'll tell you exactly which Wire Peg is right for your home.</p>
    </div>
  </section>

  <section class="py-16 px-6 bg-white">
    <div class="max-w-2xl mx-auto">

      <div id="quiz">

        <div id="q1" class="quiz-step">
          <div class="bg-navy-50 rounded-2xl border border-navy-100 p-8 mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Question 1 of 3</p>
            <h2 class="text-2xl font-bold text-navy-900 mb-6">Do you live within 10km of the ocean or a coastal area?</h2>
            <div class="flex flex-col gap-3">
              <button onclick="answer('coastal', true)" class="quiz-btn text-left bg-white hover:bg-navy-50 border border-navy-100 hover:border-teal-500 rounded-xl px-6 py-4 font-medium text-navy-700 transition-colors">Yes — I live near the coast</button>
              <button onclick="answer('coastal', false)" class="quiz-btn text-left bg-white hover:bg-navy-50 border border-navy-100 hover:border-teal-500 rounded-xl px-6 py-4 font-medium text-navy-700 transition-colors">No — I live inland</button>
            </div>
          </div>
        </div>

        <div id="q2" class="quiz-step hidden">
          <div class="bg-navy-50 rounded-2xl border border-navy-100 p-8 mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Question 2 of 3</p>
            <h2 class="text-2xl font-bold text-navy-900 mb-6">Do you leave your pegs outside on the line permanently?</h2>
            <div class="flex flex-col gap-3">
              <button onclick="answer('outside', true)" class="quiz-btn text-left bg-white hover:bg-navy-50 border border-navy-100 hover:border-teal-500 rounded-xl px-6 py-4 font-medium text-navy-700 transition-colors">Yes — they stay on the line</button>
              <button onclick="answer('outside', false)" class="quiz-btn text-left bg-white hover:bg-navy-50 border border-navy-100 hover:border-teal-500 rounded-xl px-6 py-4 font-medium text-navy-700 transition-colors">No — I bring them inside after each wash</button>
            </div>
          </div>
        </div>

        <div id="q3" class="quiz-step hidden">
          <div class="bg-navy-50 rounded-2xl border border-navy-100 p-8 mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-teal-500 mb-2">Question 3 of 3</p>
            <h2 class="text-2xl font-bold text-navy-900 mb-6">Do you ever hang large items like pillows, doonas or sleeping bags?</h2>
            <div class="flex flex-col gap-3">
              <button onclick="answer('large', true)" class="quiz-btn text-left bg-white hover:bg-navy-50 border border-navy-100 hover:border-teal-500 rounded-xl px-6 py-4 font-medium text-navy-700 transition-colors">Yes — regularly</button>
              <button onclick="answer('large', false)" class="quiz-btn text-left bg-white hover:bg-navy-50 border border-navy-100 hover:border-teal-500 rounded-xl px-6 py-4 font-medium text-navy-700 transition-colors">No — just regular laundry</button>
            </div>
          </div>
        </div>

        <div id="result" class="quiz-step hidden">
          <div id="result-box" class="bg-navy-900 text-white rounded-2xl p-8 mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-teal-300 mb-2">Our Recommendation</p>
            <h2 id="result-title" class="text-3xl font-bold mb-4"></h2>
            <p id="result-desc" class="text-navy-100 leading-relaxed mb-8"></p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a id="result-link" href="#" target="_blank" class="bg-teal-500 text-white font-semibold px-8 py-4 rounded-full hover:bg-teal-700 transition-colors text-center">Buy at Biome →</a>
              <button onclick="resetQuiz()" class="border border-navy-400 text-white font-semibold px-8 py-4 rounded-full hover:border-white transition-colors">Start Again</button>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <section class="py-12 px-6 border-t border-navy-100 bg-white">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-navy-600 text-sm mb-4">Want to browse all products instead?</p>
      <a href="/products" class="text-sm font-semibold text-teal-500 hover:text-teal-700 underline underline-offset-4">View all Wire Pegs products →</a>
    </div>
  </section>

</Layout>

<script>
  const answers: Record<string, boolean> = {};

  function answer(question: string, value: boolean) {
    answers[question] = value;

    if (question === 'coastal') {
      if (value) {
        showResult('Grade 316 — Marine Grade', 'You live near the coast, so you need the toughest grade available. Grade 316 marine stainless steel will never rust even in salty air and can be left outside permanently.', 'https://www.biome.com.au/collections/wire-pegs');
      } else {
        document.getElementById('q1')!.classList.add('hidden');
        document.getElementById('q2')!.classList.remove('hidden');
      }
    }

    if (question === 'outside') {
      if (value) {
        showResult('Grade 304 — Medium Grade', 'You leave your pegs outside, so you need a grade that can handle weathering. Grade 304 is perfect for most Australian outdoor conditions away from the coast.', 'https://www.biome.com.au/collections/wire-pegs');
      } else {
        document.getElementById('q2')!.classList.add('hidden');
        document.getElementById('q3')!.classList.remove('hidden');
      }
    }

    if (question === 'large') {
      if (value) {
        showResult('Grade 201 + Jumbo Pegs', 'You bring your pegs inside, so Grade 201 is perfect for you. And for those large items like pillows and doonas, grab some Jumbo Pegs too!', 'https://www.biome.com.au/collections/wire-pegs');
      } else {
        showResult('Grade 201 — Standard', 'You bring your pegs inside after washing, so Grade 201 is the perfect choice. Long lasting, rust resistant when cared for correctly, and a massive upgrade over plastic.', 'https://www.biome.com.au/collections/wire-pegs');
      }
    }
  }

  function showResult(title: string, desc: string, link: string) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    document.getElementById('result-title')!.textContent = title;
    document.getElementById('result-desc')!.textContent = desc;
    (document.getElementById('result-link') as HTMLAnchorElement).href = link;
    document.getElementById('result')!.classList.remove('hidden');
  }

  function resetQuiz() {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    document.getElementById('q1')!.classList.remove('hidden');
  }

  (window as any).answer = answer;
  (window as any).resetQuiz = resetQuiz;
</script>