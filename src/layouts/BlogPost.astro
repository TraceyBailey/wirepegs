---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>

  <!-- HERO -->
  <section class="py-24 px-6 bg-stone-50">
    <div class="max-w-3xl mx-auto">
      <a href="/blog" class="text-sm font-medium text-stone-400 hover:text-stone-600 transition-colors mb-8 inline-block">← Back to Blog</a>
      <p class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-4">{frontmatter.category}</p>
      <h1 class="text-4xl md:text-5xl font-bold text-stone-800 leading-tight mb-6">{frontmatter.title}</h1>
      <p class="text-xl text-stone-500 leading-relaxed mb-6">{frontmatter.description}</p>
      <p class="text-sm text-stone-400">
        {new Date(frontmatter.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto prose prose-stone prose-lg
      prose-headings:font-bold prose-headings:text-stone-800
      prose-p:text-stone-600 prose-p:leading-relaxed
      prose-a:text-stone-800 prose-a:font-medium prose-a:underline prose-a:underline-offset-4
      prose-strong:text-stone-800
      prose-ul:text-stone-600
      prose-li:text-stone-600">
      <slot />
    </div>
  </section>



</Layout>